# Copia este archivo como .env y completa los valores

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=False

# Base de datos (Railway la provee automáticamente como DATABASE_URL)
# Si usas Railway, solo necesitas DATABASE_URL y puedes omitir las de abajo
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# O bien, variables individuales (para desarrollo local)
DB_NAME=iromarket_db
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432

# Email (para reset de contraseña)
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail

# URL del frontend (para redireccionamientos)
FRONTEND_URL=https://tu-dominio-frontend.com/
